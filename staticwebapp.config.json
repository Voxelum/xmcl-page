{
  "navigationFallback": {
    "rewrite": "/en/"
  },
  "trailingSlash": "auto",
  "routes": [
    {
      "route": "/",
      "redirect": "/en/",
      "statusCode": 301
    },
    {
      "route": "/auth",
      "rewrite": "/api/lookup-auth"
    }
  ],
  "platform": {
    "apiRuntime": "node:20"
  }
}