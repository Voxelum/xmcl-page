---
import "../index.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  lang?: string;
  noindex?: boolean;
  publishedTime?: string;
  structuredData?: Record<string, unknown>;
  dir?: "ltr" | "rtl";
  ogLocale?: string;
  alternateLocales?: Array<{ href: string; hreflang: string }>;
}

const {
  title = "XMCL - X Minecraft Launcher | Modern Minecraft Launcher",
  description = "XMCL is a modern, open-source Minecraft launcher with advanced features like mod management, multiple instances, P2P sharing, and support for all mod loaders (Forge, Fabric, NeoForge, Quilt). Download now for Windows, macOS, and Linux.",
  image = "/og-image.svg",
  type = "website",
  lang = "en",
  noindex = false,
  publishedTime,
  structuredData,
  dir = "ltr",
  ogLocale = "en_US",
  alternateLocales = [],
} = Astro.props;

const siteURL = Astro.site ?? new URL("https://xmcl.app");
const canonicalURL = new URL(Astro.url.pathname, siteURL).href;
const imageURL = new URL(image, siteURL).href;
const siteName = "X Minecraft Launcher";
const twitterHandle = "@xmcl";
const normalizedPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isApplicationPage = normalizedPath === "/" || normalizedPath === "/download";
const defaultStructuredData = isApplicationPage ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "X Minecraft Launcher",
  "alternateName": "XMCL",
  "description": description,
  "url": canonicalURL,
  "image": imageURL,
  "applicationCategory": "GameApplication",
  "operatingSystem": "Windows, macOS, Linux",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
} : undefined;
const jsonLd = structuredData ?? defaultStructuredData;
const robots = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
---

<!DOCTYPE html>
<html lang={lang} dir={dir} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href="/PhotoXMCL/logo.ico" type="image/x-icon" />
    <link rel="apple-touch-icon" href="/PhotoXMCL/logo.png" />
    <link rel="canonical" href={canonicalURL} />
    {alternateLocales.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
    ))}
    <ClientRouter />
    
    <!-- Primary SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta name="author" content="Voxelum" />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="theme-color" content="#3b82f6" />
    <meta name="msapplication-TileColor" content="#3b82f6" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:creator" content={twitterHandle} />
    <meta name="twitter:site" content={twitterHandle} />
    {type === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}

    <!-- Additional SEO Tags -->
    <meta name="application-name" content="XMCL" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="XMCL" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <meta name="google" content="notranslate" />
    <script is:inline>
      if (document.cookie.includes('googtrans') && !document.cookie.includes('googtrans=/en/en')) {
        window.googleTranslateElementInit = function() {
          new google.translate.TranslateElement({
            pageLanguage: 'en',
            autoDisplay: false,
            layout: google.translate.TranslateElement.InlineLayout.SIMPLE
          }, 'google_translate_element');
        };

        const script = document.createElement('script');
        script.type = 'text/javascript';
        script.src = '//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
        document.head.appendChild(script);
      }
    </script>
    <style is:inline>
      .goog-te-banner-frame, .skiptranslate, #goog-gt-tt, .goog-te-balloon-frame {
        display: none !important;
      }
      body { top: 0 !important; }
      .goog-text-highlight { background: none !important; box-shadow: none !important; }
    </style>
    <script is:inline>
      (function() {
        function syncLangAndDir() {
          try {
            const savedLocale = localStorage.getItem("language");
            if (savedLocale) {
              document.documentElement.lang = savedLocale;
              document.documentElement.dir = savedLocale === "ar" ? "rtl" : "ltr";
            }
          } catch (e) {}
        }
        syncLangAndDir();
        document.addEventListener("astro:after-swap", syncLangAndDir);
        document.addEventListener("astro:page-load", syncLangAndDir);
      })();
    </script>
  </head>
  <body>
    <div id="google_translate_element" style="display:none"></div>
    <main transition:animate="slide" style="view-transition-name: page-content;">
      <slot />
    </main>

    <script>
      // Console Easter Egg
      console.log(`
██╗  ██║███╗   ███╗ ██████╗ ██╗
╚██╗██╔╝████╗ ████║██╔════╝ ██║
 ╚███╔╝ ██╔████╔██║██║      ██║
 ██╔██╗ ██║╚██╔╝██║██║      ██║
██╔╝ ██╗██║ ╚═╝ ██║╚██████╗ ███████╗
╚═╝  ╚═╝╚═╝     ╚═╝ ╚═════╝ ╚══════╝

THE BEST LAUNCHER !
`);

      // Easter egg functions
      (window as any).baneronetwo = () => {
        console.log('%cBANERONETWO IS THE DEVELOPER! This is not an official website yet.', 'color: #8b5cf6; font-weight: bold; font-size: 16px;');
      };
    </script>
  </body>
</html>
