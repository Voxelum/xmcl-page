---
import Layout from "../../../layouts/Layout.astro";
import { StaticArticle } from "../../../components/StaticArticle";
import { languageConfigs } from "../../../i18n/languageConfigs";
import { loadTranslationsSync } from "../../../i18n";
import { getAllBlogPosts, getBlogPost } from "../../../utils/blogUtils";
import { getHreflang, getLocaleAlternates, getLocalizedPath, getOgLocale, getText } from "../../../lib/locales";

export async function getStaticPaths() {
  const posts = await Promise.all((await getAllBlogPosts()).map((post) => getBlogPost(post.slug)));

  return languageConfigs.flatMap(({ code }) => posts.map((post) => ({
    params: { locale: code, slug: post.slug },
    props: { locale: code, post },
  })));
}

const { locale, post } = Astro.props;
const translations = loadTranslationsSync(locale) as Record<string, unknown>;
const articlePath = `/blog/${post.slug}/`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "datePublished": post.date,
  "author": {
    "@type": "Person",
    "name": post.author,
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).href,
  },
};
---

<Layout
  title={`${post.title} | XMCL Blog`}
  description={post.excerpt}
  type="article"
  lang={getHreflang(locale)}
  dir={locale === "ar" ? "rtl" : "ltr"}
  ogLocale={getOgLocale(locale)}
  publishedTime={post.date}
  alternateLocales={getLocaleAlternates(articlePath, Astro.site)}
  structuredData={structuredData}
>
  <StaticArticle
    initialLocale={locale}
    title={post.title}
    description={post.excerpt}
    author={post.author}
    date={post.date}
    content={post.content}
    backHref={getLocalizedPath(locale, "/blog/")}
    backLabel={getText(translations, "common.back", "Back")}
  />
</Layout>
