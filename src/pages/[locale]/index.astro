---
import Layout from "../../layouts/Layout.astro";
import { LocalizedPage } from "../../components/LocalizedPage";
import { languageConfigs } from "../../i18n/languageConfigs";
import { loadTranslationsSync } from "../../i18n";
import { getHreflang, getLocaleAlternates, getOgLocale, getText } from "../../lib/locales";

export function getStaticPaths() {
  return languageConfigs.map(({ code }) => ({
    params: { locale: code },
  }));
}

const locale = Astro.params.locale as SupportedLocale;
const translations = loadTranslationsSync(locale) as Record<string, unknown>;
const hreflang = getHreflang(locale);
const title = `${getText(translations, "home.heroTitle", "X Minecraft Launcher")} | X Minecraft Launcher`;
const description = getText(
  translations,
  "home.heroSubtitle",
  "A modern, open-source Minecraft launcher for Windows, macOS, and Linux.",
);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "X Minecraft Launcher",
  "alternateName": "XMCL",
  "description": description,
  "url": new URL(`/${locale}/`, Astro.site).href,
  "applicationCategory": "GameApplication",
  "operatingSystem": "Windows, macOS, Linux",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
  },
};
---

<Layout
  title={title}
  description={description}
  lang={hreflang}
  dir={locale === "ar" ? "rtl" : "ltr"}
  ogLocale={getOgLocale(locale)}
  alternateLocales={getLocaleAlternates("/", Astro.site)}
  structuredData={structuredData}
>
  <LocalizedPage client:load page="home" locale={locale} />
</Layout>
