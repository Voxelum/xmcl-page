---
import Layout from "../../layouts/Layout.astro";
import { StaticArticle } from "../../components/StaticArticle";
import { getAllGuidePosts, getGuideContent } from "../../utils/guideUtils";

export async function getStaticPaths() {
  const posts = await getAllGuidePosts('en');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, content: getGuideContent('en', post.slug) },
  }));
}

const { post, content } = Astro.props;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": post.title,
  "description": post.excerpt,
  "datePublished": post.date,
  "author": {
    "@type": "Organization",
    "name": post.author,
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).href,
  },
};
---

<Layout
  title={`${post.title} | XMCL Guide`}
  description={post.excerpt}
  type="article"
  publishedTime={post.date}
  structuredData={structuredData}
>
  <StaticArticle
    title={post.title}
    description={post.excerpt}
    author={post.author}
    date={post.date}
    content={content}
    backHref="/guide/"
    backLabel="Back to guides"
  />
</Layout>
