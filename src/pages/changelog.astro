---
import Layout from "../layouts/Layout.astro";
import LocalChangelog from "../react-pages/LocalChangelog";
import { getChangelogs } from "../utils/changelogUtils";

const changelogs = getChangelogs("en");
---

<Layout title="Changelog - X Minecraft Launcher" description="View the complete changelog and release history of X Minecraft Launcher.">
  <LocalChangelog client:load entries={changelogs} />
</Layout>
